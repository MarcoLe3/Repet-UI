generator client {
  provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url = env("POSTGRES_PRISMA_URL")
    directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Component {
  id        String @id @default(uuid())
  title     String
  content   String
  published Boolean @default(false)
  type      String
  props     Json
}

model Account {
    id              String @id @default(uuid())
    userId          String
    access_token    String?
    expires_at      Int?
    oauth_token     String?
    session_state   String?
    refresh_token   String?
    user            User @relation(fields:[userId],references:[id])
}

model Session {
    id              String @id @default(uuid())
    sessionToken    String
    expires_at      DateTime
}

model User {
    id          String @id @default(uuid())
    comment     Comment[]
    account     Account[]
}

model Comment {
    id              String @id @default(uuid())
    content         String
    published       Boolean @default(false)
    authorId        String
    author          User @relation(fields:[authorId], references: [id])
}